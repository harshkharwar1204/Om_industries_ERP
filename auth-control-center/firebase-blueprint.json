{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for role-based users",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The Firebase Auth UID of the user" },
        "email": { "type": "string", "description": "User email address" },
        "role": { "type": "string", "enum": ["owner", "manager", "worker"], "description": "The user role" },
        "displayName": { "type": "string", "description": "The readable name of the user" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role", "displayName", "createdAt", "updatedAt"]
    },
    "PrivateInfo": {
      "title": "Private Information",
      "description": "PII contacts and credentials, isolated from public access",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "mobileNumber", "updatedAt"]
    },
    "WorkerLookup": {
      "title": "Worker Lookup Card",
      "description": "Maps custom Worker IDs to dynamic Firebase credentials and mobile numbers",
      "type": "object",
      "properties": {
        "workerId": { "type": "string", "description": "Unique Username / Worker ID" },
        "mobileNumber": { "type": "string", "description": "Password mobile number of worker" },
        "userId": { "type": "string", "description": "Firebase Auth UID link" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "on_duty", "off_duty"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workerId", "mobileNumber", "userId", "name", "status", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Task Assignment",
      "description": "Task created by manager/owner and assigned to a worker",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedWorkerId": { "type": "string" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "title", "description", "assignedWorkerId", "createdBy", "status", "createdAt", "updatedAt"]
    },
    "Party": {
      "title": "Party Master",
      "description": "A business party register for the ERP system.",
      "type": "object",
      "properties": {
        "partyId": { "type": "string", "description": "Unique Party key" },
        "partyName": { "type": "string", "description": "Legal name of the business party" },
        "mobile": { "type": "string", "description": "Contact mobile number" },
        "city": { "type": "string", "description": "Trading city" },
        "gst": { "type": "string", "description": "GST number if registered" },
        "address": { "type": "string", "description": "Full business address" },
        "paymentTerms": { "type": "string", "description": "Default payment terms or days" },
        "isDeleted": { "type": "boolean", "description": "True if soft-deleted" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["partyId", "partyName", "mobile", "city", "gst", "address", "paymentTerms", "isDeleted", "createdAt", "updatedAt"]
    },
    "Item": {
      "title": "Item Master",
      "description": "An item/product master register for the ERP system.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string", "description": "Unique Item key" },
        "itemName": { "type": "string", "description": "Product / Item full name" },
        "itemCode": { "type": "string", "description": "Item identifying code or SKU" },
        "unit": { "type": "string", "description": "Standard unit of measurement" },
        "description": { "type": "string", "description": "Extended notes or details" },
        "isDeleted": { "type": "boolean", "description": "True if soft-deleted" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "itemName", "itemCode", "unit", "description", "isDeleted", "createdAt", "updatedAt"]
    },
    "Shade": {
      "title": "Shade Master",
      "description": "A shade / color reference register for the ERP system.",
      "type": "object",
      "properties": {
        "shadeId": { "type": "string", "description": "Unique Shade key" },
        "shadeName": { "type": "string", "description": "Name designation of the shade" },
        "shadeCode": { "type": "string", "description": "Color code or recipe formula card number" },
        "description": { "type": "string", "description": "Extended shade details" },
        "isDeleted": { "type": "boolean", "description": "True if soft-deleted" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shadeId", "shadeName", "shadeCode", "description", "isDeleted", "createdAt", "updatedAt"]
    },
    "Machine": {
      "title": "Machine Master",
      "description": "A production machine register for the ERP system.",
      "type": "object",
      "properties": {
        "machineId": { "type": "string", "description": "Unique Machine key" },
        "machineName": { "type": "string", "description": "Readable name of the machine" },
        "machineCode": { "type": "string", "description": "System-wide identifier/code" },
        "capacity": { "type": "string", "description": "Full volumetric capacity limit" },
        "machineType": { "type": "string", "description": "Manufacturing type classification" },
        "status": { "type": "string", "enum": ["active", "inactive", "maintenance"], "description": "Operating condition" },
        "isDeleted": { "type": "boolean", "description": "True if soft-deleted" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["machineId", "machineName", "machineCode", "capacity", "machineType", "status", "isDeleted", "createdAt", "updatedAt"]
    },
    "Rate": {
      "title": "Rate Master",
      "description": "A custom pricing rate schedule for combinations of Party, Item, and Shade.",
      "type": "object",
      "properties": {
        "rateId": { "type": "string", "description": "Unique Rate entry key" },
        "partyId": { "type": "string", "description": "Reference party ID" },
        "itemId": { "type": "string", "description": "Reference item ID" },
        "shadeId": { "type": "string", "description": "Reference shade ID, or 'none'" },
        "rate": { "type": "number", "description": "The base billing rate" },
        "effectiveDate": { "type": "string", "description": "Effective starting date of price sched" },
        "isDeleted": { "type": "boolean", "description": "True if soft-deleted" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rateId", "partyId", "itemId", "shadeId", "rate", "effectiveDate", "isDeleted", "createdAt", "updatedAt"]
    },
    "WorkerMaster": {
      "title": "Worker Master",
      "description": "A physical/shift worker profile register for the ERP system.",
      "type": "object",
      "properties": {
        "workerId": { "type": "string", "description": "Unique Auto Worker key" },
        "workerName": { "type": "string", "description": "Name specification" },
        "mobile": { "type": "string", "description": "Cellular phone number" },
        "address": { "type": "string", "description": "Postal street address" },
        "unit": { "type": "string", "description": "Processing department unit" },
        "role": { "type": "string", "description": "Job operational classification" },
        "rate": { "type": "number", "description": "Piece/wage compensation rate" },
        "isDeleted": { "type": "boolean", "description": "True if soft-deleted" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workerId", "workerName", "mobile", "address", "unit", "role", "rate", "isDeleted", "createdAt", "updatedAt"]
    },
    "PartyOrder": {
      "title": "Party Order",
      "description": "A corporate client's purchase order details registry.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string", "description": "Unique auto-generated sequential order identifier, e.g. ORD-0001" },
        "partyId": { "type": "string", "description": "Linked Party Identifier" },
        "partyName": { "type": "string", "description": "Cached Party legal name" },
        "poNumber": { "type": "string", "description": "Purchase Order authorization reference code" },
        "itemId": { "type": "string", "description": "Linked Item Identifier" },
        "itemName": { "type": "string", "description": "Cached Item reference title" },
        "count": { "type": "string", "description": "Yarn Count / technical specs of item" },
        "shadeId": { "type": "string", "description": "Linked shade recipe formulary code" },
        "shadeName": { "type": "string", "description": "Cached Shade designation" },
        "qtyKg": { "type": "number", "description": "Total weight quantity of items in Kg" },
        "rate": { "type": "number", "description": "Agreed price rate per unit Kg" },
        "deliveryDate": { "type": "string", "description": "Expected dispatch fulfillment date" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Completed", "Cancelled"] },
        "isDeleted": { "type": "boolean", "description": "True if soft archived" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "partyId", "partyName", "poNumber", "itemId", "itemName", "count", "shadeId", "shadeName", "qtyKg", "rate", "deliveryDate", "priority", "status", "isDeleted", "createdAt", "updatedAt"]
    },
    "GreyStock": {
      "title": "Grey Stock Lot",
      "description": "A grey yarn stock receipt lot registry entry.",
      "type": "object",
      "properties": {
        "lotId": { "type": "string", "description": "Unique auto-generated sequential Lot identifier, e.g. L-001" },
        "date": { "type": "string", "description": "Receiving date" },
        "challanNo": { "type": "string", "description": "Challan delivery reference index number" },
        "partyId": { "type": "string", "description": "Linked Party Identifier" },
        "partyName": { "type": "string", "description": "Cached Party legal name" },
        "orderId": { "type": "string", "description": "Associated order ID index code or none" },
        "itemId": { "type": "string", "description": "Linked Yarn product Item ID" },
        "itemName": { "type": "string", "description": "Cached Item reference title" },
        "count": { "type": "string", "description": "Yarn Count of stock product, e.g. 2/40s Ne" },
        "receivedQtyKg": { "type": "number", "description": "Total weighed yarn received in kilograms" },
        "conesBags": { "type": "number", "description": "Units count of Cones or Bags packaged" },
        "isDeleted": { "type": "boolean", "description": "True if soft archived" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["lotId", "date", "challanNo", "partyId", "partyName", "orderId", "itemId", "itemName", "count", "receivedQtyKg", "conesBags", "isDeleted", "createdAt", "updatedAt"]
    },
    "HanksProduction": {
      "title": "Hanks Production Item",
      "description": "Hanks processing/production bag output registry.",
      "type": "object",
      "properties": {
        "productionId": { "type": "string", "description": "Unique sequentially generated ID, e.g. HP-0001" },
        "lotId": { "type": "string", "description": "Linked Lot number ID, e.g. L-001" },
        "bagNo": { "type": "string", "description": "Sequentially derived Bag format code, e.g. L-001-B01" },
        "workerId": { "type": "string", "description": "Linked worker master identity reference" },
        "workerName": { "type": "string", "description": "Cached worker name" },
        "process": { "type": "string", "description": "Name of manufacturing operation step, e.g. Reeling" },
        "inputKg": { "type": "number", "description": "Total weight of yarn feedstock in Kg" },
        "outputKg": { "type": "number", "description": "Total finished weight of yarn outputs in Kg" },
        "lossPercent": { "type": "number", "description": "Derived wastage percentage" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Completed", "Approved"] },
        "isDeleted": { "type": "boolean", "description": "True if soft archived" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productionId", "lotId", "bagNo", "workerId", "workerName", "process", "inputKg", "outputKg", "lossPercent", "status", "isDeleted", "createdAt", "updatedAt"]
    },
    "DyeingProduction": {
      "title": "Dyeing Production Item",
      "description": "Dyeing process run and yarn lot/bag coloring ledger.",
      "type": "object",
      "properties": {
        "dyeingId": { "type": "string", "description": "Unique sequentially generated ID, e.g. DP-0001" },
        "lotId": { "type": "string", "description": "Linked Lot number ID, e.g. L-001" },
        "bagNo": { "type": "string", "description": "Linked Bag sequence ID, e.g. L-001-B01" },
        "partyName": { "type": "string", "description": "Derived client or party name" },
        "shade": { "type": "string", "description": "Target yarn shade or color spec" },
        "recipe": { "type": "string", "description": "Recipe configuration prescription code" },
        "machine": { "type": "string", "description": "Assigned dyeing machine code/id" },
        "operatorId": { "type": "string", "description": "Assigned Operator worker ID" },
        "operatorName": { "type": "string", "description": "Cached Operator name" },
        "helperId": { "type": "string", "description": "Assigned Helper worker ID" },
        "helperName": { "type": "string", "description": "Cached Helper name" },
        "inputKg": { "type": "number", "description": "Weighed raw input hanks yarn feed weight in Kg" },
        "outputKg": { "type": "number", "description": "Weighed exit dyed yarn output weight in Kg" },
        "lossPercent": { "type": "number", "description": "Resulting percentage waste-loss" },
        "status": { "type": "string", "enum": ["Pending", "Running", "Completed", "Rework", "Rejected"] },
        "isDeleted": { "type": "boolean", "description": "True if soft archived" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dyeingId", "lotId", "bagNo", "partyName", "shade", "recipe", "machine", "operatorId", "operatorName", "helperId", "helperName", "inputKg", "outputKg", "lossPercent", "status", "isDeleted", "createdAt", "updatedAt"]
    },
    "ConningProduction": {
      "title": "Conning Production Item",
      "description": "Conning / Cone winding process and yarn lot packaging quality ledger.",
      "type": "object",
      "properties": {
        "conningId": { "type": "string", "description": "Unique sequentially generated ID, e.g. CP-0001" },
        "lotId": { "type": "string", "description": "Linked Lot ID, e.g. L-001" },
        "bagNo": { "type": "string", "description": "Linked Bag or Dyeing run ID, e.g. L-001-B01" },
        "partyName": { "type": "string", "description": "Derived client or party name" },
        "shade": { "type": "string", "description": "Target yarn shade/color spec" },
        "coneWeight": { "type": "number", "description": "Unit target cone weight in Kg" },
        "conesCount": { "type": "number", "description": "Total number of cones wound" },
        "outputKg": { "type": "number", "description": "Total physical conning output weight" },
        "quality": { "type": "string", "enum": ["Pass", "Reject"] },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Completed"] },
        "isDeleted": { "type": "boolean", "description": "True if soft archived" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["conningId", "lotId", "bagNo", "partyName", "shade", "coneWeight", "conesCount", "outputKg", "quality", "status", "isDeleted", "createdAt", "updatedAt"]
    },
    "ReadyStock": {
      "title": "Ready Stock Item",
      "description": "Fully processed and quality-checked finished goods ready for dispatch.",
      "type": "object",
      "properties": {
        "stockId": { "type": "string", "description": "Unique sequentially generated finished goods reference ID, e.g. RS-0001" },
        "lotId": { "type": "string", "description": "Linked original Lot ID reference" },
        "bagNo": { "type": "string", "description": "Linked Bag sequence ID, e.g. L-001-B01" },
        "partyName": { "type": "string", "description": "Derived client or party name" },
        "shade": { "type": "string", "description": "Target yarn shade or color spec" },
        "conesCount": { "type": "number", "description": "Number of cones in stock pack" },
        "weightKg": { "type": "number", "description": "Net physical weight in Kg" },
        "grade": { "type": "string", "enum": ["A Grade", "Standard Grade", "B Grade"] },
        "warehouseLocation": { "type": "string", "description": "Warehouse racking / physical location index" },
        "status": { "type": "string", "enum": ["Available", "Reserved", "Dispatched"] },
        "conningIdReference": { "type": "string", "description": "Reference conning batch ID link" },
        "isDeleted": { "type": "boolean", "description": "True if soft archived" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["stockId", "lotId", "bagNo", "partyName", "shade", "conesCount", "weightKg", "grade", "warehouseLocation", "status", "isDeleted", "createdAt", "updatedAt"]
    },
    "DispatchTransaction": {
      "title": "Dispatch Transaction",
      "description": "Log of dispatched finished goods and invoicing",
      "type": "object",
      "properties": {
        "dispatchId": { "type": "string" },
        "invoiceNo": { "type": "string" },
        "partyId": { "type": "string" },
        "partyName": { "type": "string" },
        "orderId": { "type": "string" },
        "lotId": { "type": "string" },
        "itemName": { "type": "string" },
        "shade": { "type": "string" },
        "dispatchKg": { "type": "number" },
        "rate": { "type": "number" },
        "amount": { "type": "number" },
        "vehicleNo": { "type": "string" },
        "lrNo": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Dispatched", "Cancelled"] },
        "isDeleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dispatchId", "invoiceNo", "partyId", "partyName", "orderId", "lotId", "itemName", "shade", "dispatchKg", "rate", "amount", "vehicleNo", "lrNo", "status", "isDeleted", "createdAt", "updatedAt"]
    },
    "PaymentCollection": {
      "title": "Payment Collection",
      "description": "Log of cash/online payments received from commercial parties",
      "type": "object",
      "properties": {
        "paymentId": { "type": "string" },
        "partyId": { "type": "string" },
        "partyName": { "type": "string" },
        "paymentDate": { "type": "string" },
        "mode": { "type": "string", "enum": ["Cash", "UPI", "Bank Transfer", "Cheque"] },
        "referenceNo": { "type": "string" },
        "amount": { "type": "number" },
        "notes": { "type": "string" },
        "isDeleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["paymentId", "partyId", "partyName", "paymentDate", "mode", "referenceNo", "amount", "notes", "isDeleted", "createdAt", "updatedAt"]
    },
    "LedgerAdjustment": {
      "title": "Ledger Adjustment",
      "description": "Commercial ledger adjust accounts adjustments",
      "type": "object",
      "properties": {
        "adjustmentId": { "type": "string" },
        "partyId": { "type": "string" },
        "partyName": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["Debit", "Credit"] },
        "particulars": { "type": "string" },
        "amount": { "type": "number" },
        "isDeleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adjustmentId", "partyId", "partyName", "date", "type", "particulars", "amount", "isDeleted", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Access public information about users"
    },
    "users/{userId}/private/info": {
      "schema": "PrivateInfo",
      "description": "PII for a specific authenticated user"
    },
    "workers/{workerId}": {
      "schema": "WorkerLookup",
      "description": "Workers index lookup mapping Worker IDs"
    },
    "worker_masters/{workerId}": {
      "schema": "WorkerMaster",
      "description": "Full staff lists and compensation attributes master ledgers"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Operational tasks assigned to workers"
    },
    "parties/{partyId}": {
      "schema": "Party",
      "description": "Business parties master directory"
    },
    "items/{itemId}": {
      "schema": "Item",
      "description": "Products and items master catalog"
    },
    "shades/{shadeId}": {
      "schema": "Shade",
      "description": "Color shades registry"
    },
    "machines/{machineId}": {
      "schema": "Machine",
      "description": "Production machinery assets index"
    },
    "rates/{rateId}": {
      "schema": "Rate",
      "description": "Custom billing rate schemas"
    },
    "party_orders/{orderId}": {
      "schema": "PartyOrder",
      "description": "Commercial client purchase order logs database ledger"
    },
    "grey_stocks/{lotId}": {
      "schema": "GreyStock",
      "description": "Yarn grey raw stock lot inward master index ledgers"
    },
    "hanks_productions/{productionId}": {
      "schema": "HanksProduction",
      "description": "Hanks production and yarn processing bag outputs track registry"
    },
    "dyeing_productions/{dyeingId}": {
      "schema": "DyeingProduction",
      "description": "Dyeing production batches and processing tracking registry"
    },
    "conning_productions/{conningId}": {
      "schema": "ConningProduction",
      "description": "Conning / Cone winding production runs tracking"
    },
    "ready_stocks/{stockId}": {
      "schema": "ReadyStock",
      "description": "Ready Stock and finished goods inventory ledger"
    },
    "dispatches/{dispatchId}": {
      "schema": "DispatchTransaction",
      "description": "Logs of finished good dispatch invoices issued"
    },
    "payment_collections/{paymentId}": {
      "schema": "PaymentCollection",
      "description": "Logs of payments received of party clients"
    },
    "ledger_adjustments/{adjustmentId}": {
      "schema": "LedgerAdjustment",
      "description": "Log of general accounting debit/credit adjustments"
    }
  }
}
